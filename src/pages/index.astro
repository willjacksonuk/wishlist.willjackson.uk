---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import WishlistItem from "../components/WishlistItem.astro";
import { ThemeToggle } from "@/components/starwind/theme-toggle";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";

const reader = createReader(process.cwd(), keystaticConfig);
const items = await reader.collections.wishlist.all();
const meta = await reader.singletons.meta.read();

const title = meta?.title ?? "Wishlist";
const subtitle = meta?.subtitle ?? "";
---

<Layout title={title}>
  <main class="min-h-screen flex flex-col">
    <header
      class="border-b border-border bg-background/80 backdrop-blur-sm sticky top-0 z-10"
    >
      <div
        class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between"
      >
        <span class="text-xl font-medium text-muted-foreground tracking-wide"
          >{title}</span
        >
        <ThemeToggle />
      </div>
    </header>

    <div class="max-w-5xl mx-auto px-6 w-full flex-1">
      <section class="py-16 text-center">
        <h1 class="text-5xl font-bold tracking-tight mb-3">
          {title}
        </h1>
        <p class="text-muted-foreground text-base">
          {subtitle}
        </p>
      </section>

      <section class="pb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {items.map((item) => <WishlistItem item={item.entry} />)}
        </div>
      </section>
    </div>

    <footer class="border-t border-border py-6">
      <div class="max-w-5xl mx-auto px-6 flex justify-center">
        <p class="text-xs text-muted-foreground/50">
          Last updated <time
            >{
              new Date().toLocaleDateString("en-GB", {
                month: "long",
                year: "numeric",
              })
            }</time
          >
        </p>
      </div>
    </footer>
  </main>
</Layout>
